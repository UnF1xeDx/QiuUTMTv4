			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_get_visible" Pure="true" ReturnType="Bool">
			<Description>此函数可用于检查给定视口的可见性。如果可见，函数将返回true，否则返回false。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_get_wport" Pure="true" ReturnType="Real">
			<Description>此函数可用于检索给定视图端口的宽度。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_get_xport" Pure="true" ReturnType="Real">
			<Description>此函数可用于检索给定视图端口的x位置。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_get_yport" Pure="true" ReturnType="Real">
