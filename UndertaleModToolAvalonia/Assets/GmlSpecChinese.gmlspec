			<Parameter Name="length" Optional="true" Type="Real">函数应该执行多少个条目。负值将以相反的顺序遍历数组。默认为array_length() - 1。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_reverse" Pure="true" ReturnType="Array">
			<Description>使用此函数，您可以用倒序的元素创建一个新数组。此函数允许自定义范围定义。</Description>
			<Parameter Name="array" Optional="false" Type="Array">保存数组的变量。</Parameter>
			<Parameter Name="offset" Optional="true" Type="Real">执行函数时要使用的偏移量。负值将从数组末尾开始计数。默认值为0。</Parameter>
			<Parameter Name="length" Optional="true" Type="Real">函数应该执行多少个条目。负值将以相反的顺序遍历数组。默认为array_length() - 1。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_reverse_ext" Pure="false" ReturnType="Real">
			<Description>使用此函数，您可以改变现有数组的元素顺序。此函数返回反转元素的数量。此函数允许自定义范围定义。</Description>
			<Parameter Name="array" Optional="false" Type="Array">保存数组的变量。</Parameter>
			<Parameter Name="offset" Optional="true" Type="Real">执行函数时要使用的偏移量。负值将从数组末尾开始计数。默认值为0。</Parameter>
			<Parameter Name="length" Optional="true" Type="Real">函数应该执行多少个条目。负值将以相反的顺序遍历数组。默认为array_length() - 1。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_concat" Pure="true" ReturnType="Array">
			<Description>使用这个函数，您可以将两个或多个数组连接成一个数组。</Description>
			<Parameter Name="array0" Optional="false" Type="Array">保存第一个数组的变量。</Parameter>
			<Parameter Name="array1" Optional="false" Type="Array">保存第二个数组的变量。</Parameter>
			<Parameter Name="..." Optional="true" Type="Array">保存第n个数组的变量。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_union" Pure="true" ReturnType="Array">
			<Description>通过此函数，您可以将两个或多个数组合并为一个，删除重复项</Description>
			<Parameter Name="array0" Optional="false" Type="Array">保存第一个数组的变量。</Parameter>
			<Parameter Name="array1" Optional="false" Type="Array">保存第二个数组的变量。</Parameter>
			<Parameter Name="..." Optional="true" Type="Array">保存第n个数组的变量。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_intersection" Pure="true" ReturnType="Array">
			<Description>使用此函数，您可以创建所有输入数组共有的元素数组，删除重复项。</Description>
			<Parameter Name="array0" Optional="false" Type="Array">保存第一个数组的变量。</Parameter>
