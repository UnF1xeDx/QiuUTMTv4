			<Parameter Name="y1" Optional="false" Type="Real">圆心的y坐标。</Parameter>
			<Parameter Name="rad" Optional="false" Type="Real">圆的半径。</Parameter>
		</Function>
		<Function Deprecated="false" Name="point_in_rectangle" Pure="true" ReturnType="Bool">
