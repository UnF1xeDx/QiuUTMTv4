		<Constant Class="VirtualKeyboardReturnType" Deprecated="false" Name="kbv_returnkey_emergency" Type="Real"/>
		<Constant Class="VirtualKeyboardAutoCapitalizeType" Deprecated="false" Name="kbv_autocapitalize_none" Type="Real"/>
		<Constant Class="VirtualKeyboardAutoCapitalizeType" Deprecated="false" Name="kbv_autocapitalize_words" Type="Real"/>
		<Constant Class="VirtualKeyboardAutoCapitalizeType" Deprecated="false" Name="kbv_autocapitalize_sentences" Type="Real"/>
		<Constant Class="VirtualKeyboardAutoCapitalizeType" Deprecated="false" Name="kbv_autocapitalize_characters" Type="Real"/>
		<Constant Class="NineSlice" Deprecated="false" Name="nineslice_center" Type="Real"/>
		<Constant Class="SequenceTrackType" Deprecated="false" Locale="US" Name="seqtracktype_color" Type="Real">这是一个颜色数据参数轨道。</Constant>
		<Constant Deprecated="false" Name="seqinterpolation_assign" Type="Real"/>
		<Constant Deprecated="false" Name="seqinterpolation_lerp" Type="Real"/>
		<Constant Class="AnimCurveInterpolationType" Deprecated="false" Name="animcurvetype_linear" Type="Real"/>
		<Constant Class="AnimCurveInterpolationType" Deprecated="false" Name="animcurvetype_catmullrom" Type="Real"/>
		<Constant Class="AnimCurveInterpolationType" Deprecated="false" Name="animcurvetype_bezier" Type="Real"/>
		<Constant Class="VideoFormat" Deprecated="false" Name="video_format_rgba" Type="Real"/>
		<Constant Class="VideoFormat" Deprecated="false" Name="video_format_yuv" Type="Real"/>
		<Constant Class="VideoStatus" Deprecated="false" Name="video_status_closed" Type="Real"/>
		<Constant Class="VideoStatus" Deprecated="false" Name="video_status_preparing" Type="Real"/>
		<Constant Class="VideoStatus" Deprecated="false" Name="video_status_playing" Type="Real"/>
		<Constant Class="VideoStatus" Deprecated="false" Name="video_status_paused" Type="Real"/>
		<Constant Class="TimeSource" Deprecated="false" Name="time_source_global" Type="Real"/>
		<Constant Class="TimeSource" Deprecated="false" Name="time_source_game" Type="Real"/>
		<Constant Class="TimeSourceUnits" Deprecated="false" Name="time_source_units_seconds" Type="Real"/>
		<Constant Class="TimeSourceUnits" Deprecated="false" Name="time_source_units_frames" Type="Real"/>
		<Constant Class="TimeSourceExpiryType" Deprecated="false" Name="time_source_expire_nearest" Type="Real"/>
		<Constant Class="TimeSourceExpiryType" Deprecated="false" Name="time_source_expire_after" Type="Real"/>
		<Constant Class="TimeSourceState" Deprecated="false" Name="time_source_state_initial" Type="Real"/>
		<Constant Class="TimeSourceState" Deprecated="false" Name="time_source_state_active" Type="Real"/>
		<Constant Class="TimeSourceState" Deprecated="false" Name="time_source_state_paused" Type="Real"/>
		<Constant Class="TimeSourceState" Deprecated="false" Name="time_source_state_stopped" Type="Real"/>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_connected_to_peer" Type="Real">当(在rollback_event_param中)player_id被连接时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_synchronizing_with_peer" Type="Real">当(在rollback_event_param中)player_id正在同步时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_synchronized_with_peer" Type="Real">当(在rollback_event_param中)player_id完成同步时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_disconnected_from_peer" Type="Real">当(在rollback_event_param中)player_id断开连接时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_game_interrupted" Type="Real">当游戏被(在rollback_event_param中)player_id中断时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_game_resumed" Type="Real">当游戏被(在rollback_event_param中)player_id中断后恢复时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_game_full" Type="Real">当你尝试加入的游戏已经满员时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_game_info" Type="Real">当您收到关于游戏的返回信息(在rollback_event_param中)player_id和num_players时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_connection_rejected" Type="Real">连接尝试被拒绝时触发。错误可能是由无效的令牌、客户端版本不匹配、协议版本不匹配引起的。多人游戏会话在事件被触发前自动关闭</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_protocol_rejected" Type="Real">连接尝试被拒绝时触发。该错误意味着客户端使用的是该协议的过时版本。在此事件触发之前，GM将在UI中显示一条错误消息。多人游戏会话在事件被触发前自动关闭</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_end_game" Type="Real">当服务器希望客户端停止游戏时触发。通常，此事件意味着客户端处于不一致状态。多人游戏会话在事件被触发前自动关闭</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_chat_message" Type="Real">当您收到聊天消息，包括本地玩家发来的消息(在rollback_event_param消息中)时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_player_prefs" Type="Real">当您收到游戏中任何玩家设置的新首选项时触发，包括由本地玩家(在rollback_event_param首选项中)和player_id设置的首选项</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_high_latency" Type="Real">当服务器的延迟太高，无法运行游戏时触发。多人游戏会话在事件被触发前自动关闭</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_connect_info" Type="Real">当你获得玩家应该连接到哪里的信息时触发(在rollback_event_param中)</Constant>
		<Constant Deprecated="false" FeatureFlag="rollback" Name="rollback_connect_error" Type="Real">当您无法连接到后端时触发</Constant>
		<Constant Deprecated="false" FeatureFlag="audio-fx" Name="audio_bus_main" Type="Struct.AudioBus">主音频总线</Constant>
    </Constants>
	<Structures>
		<Structure Name="Sequence">
			<Field Get="true" Name="name" Set="true" Type="String">这是字符串形式的序列名称，您可以根据需要获取或设置该值。注意，使用sequence_create()函数创建的序列没有名称，而只是一个空字符串&quot;&quot;。</Field>
			<Field Get="true" Name="loopmode" Set="true" Type="Constant.SeqPlay">这是序列对象的回放模式，可以获取或设置。</Field>
			<Field Get="true" Name="playbackSpeed" Set="true" Type="Real">这指定了序列的回放速度，根据playbackSpeedType(见下文)，该速度被解释为每秒帧数或每游戏帧帧数。您可以获取或设置该值。</Field>
			<Field Get="true" Name="playbackSpeedType" Set="true" Type="Constant.SpriteSpeed">这指定了应该如何解释playbackSpeed，并且您可以获取或设置该值。</Field>
			<Field Get="true" Name="length" Set="true" Type="Real">帧中序列的长度。您可以获取或设定此值，但注意，如果引用此序列的序列实例将其播放头设定为超过新长度，则缩短序列可能会导致问题。</Field>
			<Field Get="true" Name="volume" Set="true" Type="Real">这是一个从0到1的标量值，用于缩放序列中所有音频轨道的音量。您可以获取或设置该值，它将修改所有轨道的全局音频输出-例如，如果您有一个音量为0.8的音频轨道，然后将序列音量属性设置为0.5，则该音频轨道的最终音量将为0.4。</Field>
			<Field Get="true" Name="xorigin" Set="true" Type="Real">这是X轴上序列的原点。</Field>
			<Field Get="true" Name="yorigin" Set="true" Type="Real">这是Y轴上序列的原点。</Field>
			<Field Get="true" Name="messageEventKeyframes" Set="true" Type="Array">这允许访问序列的信息事件关键帧。您可以获取或设置这些消息事件，当获取此属性时，将返回一个关键帧结构数组，为了设置该属性，您应该提供一个关键帧结构数组。欲了解更多信息，请参阅序列事件和时刻页面。</Field>
			<Field Get="true" Name="momentKeyframes" Set="true" Type="Array">这允许访问序列的瞬间事件关键帧。您可以获取或设置这些moment事件，当获取此属性时，将返回一个关键帧结构数组，为了设置该属性，您应该提供一个关键帧结构数组。欲了解更多信息，请参阅序列事件和时刻页面。</Field>
			<Field Get="true" Name="tracks" Set="true" Type="Array">这允许访问序列顶层的资源轨道列表。您可以获取或设置此属性，当获取此属性时，将返回一个跟踪结构数组，为了设置该属性，您应该提供一个跟踪结构数组。有关更多信息，请参见跟踪结构一节。</Field>
		</Structure>
		<Structure Name="SequenceInstance">
			<Field Get="true" Name="sequence" Set="true" Type="Struct.Sequence"/>
			<Field Get="true" Name="headPosition" Set="true" Type="Real"/>
			<Field Get="true" Name="headDirection" Set="true" Type="Constant.SequenceDirection"/>
			<Field Get="true" Name="speedScale" Set="true" Type="Real"/>
			<Field Get="true" Name="volume" Set="true" Type="Real"/>
			<Field Get="true" Name="paused" Set="true" Type="Bool"/>
			<Field Get="true" Name="finished" Set="true" Type="Bool"/>
			<Field Get="true" Name="activeTracks" Set="true" Type="Array[Struct.ActiveTrack]"/>
			<Field Get="true" Name="elementID" Set="true" Type="Id.SequenceElement"/>
		</Structure>
		<Structure Name="Track">
			<Field Get="true" Name="name" Set="true" Type="String"/>
			<Field Get="true" Name="type" Set="true" Type="Constant.SequenceTrackType"/>
			<Field Get="true" Name="tracks" Set="true" Type="Array[Struct.Track]"/>
			<Field Get="true" Name="visible" Set="true" Type="Bool"/>
			<Field Get="true" Name="keyframes" Set="true" Type="Array[Struct.Keyframe]"/>
		</Structure>
		<Structure Name="Keyframe">
			<Field Get="true" Name="frame" Set="true" Type="Real"/>
			<Field Get="true" Name="length" Set="true" Type="Real"/>
			<Field Get="true" Name="stretch" Set="true" Type="Bool"/>
			<Field Get="true" Name="disabled" Set="true" Type="Bool"/>
			<Field Get="true" Name="channels" Set="true" Type="Array"/>
		</Structure>
		<Structure Name="KeyChannel">
			<Field Get="true" Name="channel" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="GraphicTrack">
			<Field Get="true" Name="spriteIndex" Set="true" Type="Asset.GMSprite"/>
		</Structure>
		<Structure Name="SequenceTrack">
			<Field Get="true" Name="sequence" Set="true" Type="Undefined"/>
		</Structure>
		<Structure Name="AudioTrack">
			<Field Get="true" Name="soundIndex" Set="true" Type="Asset.GMSound"/>
			<Field Get="true" Name="emitterIndex" Set="true" Type="Id.EmitterIndex"/>
			<Field Get="true" Name="playbackMode" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="SpriteTrack">
			<Field Get="true" Name="imageIndex" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="BoolTrack">
			<Field Get="true" Name="value" Set="true" Type="Bool"/>
		</Structure>
		<Structure Name="StringTrack">
			<Field Get="true" Name="value" Set="true" Type="String"/>
		</Structure>
		<Structure Name="ColourTrack">
			<Field Get="true" Name="colour" Set="true" Type="Constant.Color"/>
		</Structure>
		<Structure Name="ColorTrack">
			<Field Get="true" Locale="US" Name="color" Set="true" Type="Constant.Color"/>
		</Structure>
		<Structure Name="RealTrack">
			<Field Get="true" Name="value" Set="true" Type="Real"/>
			<Field Get="true" Name="curve" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="InstanceTrack">
			<Field Get="true" Name="objectIndex" Set="true" Type="Asset.GMObject"/>
		</Structure>
		<Structure Name="TextTrack">
			<Field Get="true" Name="text" Set="true" Type="String"/>
		</Structure>
		<Structure Name="MessageEvent">
			<Field Get="true" Name="events" Set="true" Type="Array"/>
		</Structure>
		<Structure Name="Moment">
			<Field Get="true" Name="event" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="AnimCurve">
			<Field Get="true" Name="name" Set="true" Type="String"/>
			<Field Get="true" Name="graphType" Set="true" Type="Real"/>
			<Field Get="true" Name="channels" Set="true" Type="Array"/>
		</Structure>
		<Structure Name="AnimCurveChannel">
			<Field Get="true" Name="type" Set="true" Type="Constant.AnimCurveChannel"/>
			<Field Get="true" Name="iterations" Set="true" Type="Real"/>
			<Field Get="true" Name="points" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="AnimCurvePoint">
			<Field Get="true" Name="posx" Set="true" Type="Real"/>
			<Field Get="true" Name="value" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="ActiveTrack">
			<Field Get="true" Name="activeTracks" Set="false" Type="Array[Struct.Track]"/>
			<Field Get="true" Name="matrix" Set="true" Type="Array"/>
			<Field Get="true" Name="posx" Set="true" Type="Real"/>
			<Field Get="true" Name="posy" Set="true" Type="Real"/>
			<Field Get="true" Name="scalex" Set="true" Type="Real"/>
			<Field Get="true" Name="scaley" Set="true" Type="Real"/>
			<Field Get="true" Name="xorigin" Set="true" Type="Real"/>
			<Field Get="true" Name="yorigin" Set="true" Type="Real"/>
			<Field Get="true" Name="gain" Set="true" Type="Real"/>
			<Field Get="true" Name="pitch" Set="true" Type="Real"/>
			<Field Get="true" Name="width" Set="true" Type="Real"/>
			<Field Get="true" Name="height" Set="true" Type="Real"/>
			<Field Get="true" Name="imageindex" Set="true" Type="Real"/>
			<Field Get="true" Name="imagespeed" Set="true" Type="Real"/>
			<Field Get="true" Locale="US" Name="colorMultiply" Set="true" Type="Array"/>
			<Field Get="true" Locale="GB" Name="colourMultiply" Set="true" Type="Array"/>
			<Field Get="true" Name="emitterIndex" Set="true" Type="Id.AudioEmitter"/>
			<Field Get="true" Name="track" Set="true" Type="Struct.Track"/>
			<Field Get="true" Name="parent" Set="true" Type="Struct.SequenceInstance"/>
			<Field Get="true" Name="frameSizeX" Set="true" Type="Real"/>
			<Field Get="true" Name="frameSizeY" Set="true" Type="Real"/>
			<Field Get="true" Name="characterSpacing" Set="true" Type="Real"/>
			<Field Get="true" Name="lineSpacing" Set="true" Type="Real"/>
			<Field Get="true" Name="paragraphSpacing" Set="true" Type="Real"/>
		</Structure>
		<Structure Name="GCStats">
			<Field Get="true" Name="objects_touched" Set="true" Type="Real"/>
			<Field Get="true" Name="objects_collected" Set="true" Type="Real"/>
			<Field Get="true" Name="traversal_time" Set="true" Type="Real"/>
			<Field Get="true" Name="collection_time" Set="true" Type="Real"/>
			<Field Get="true" Name="gc_frame" Set="true" Type="Real"/>
			<Field Get="true" Name="generation_collected" Set="true" Type="Real"/>
			<Field Get="true" Name="num_generations" Set="true" Type="Real"/>
			<Field Get="true" Name="num_objects_in_generation" Set="true" Type="Array"/>
		</Structure>
		<Structure Name="WeakRef">
			<Field Get="true" Name="ref" Set="true" Type="ArgumentIdentity"/>
		</Structure>
		<Structure Name="FontInfo">
			<Field Get="true" Name="ascenderOffset" Set="false" Type="Real"/>
			<Field Get="true" Name="size" Set="false" Type="Real"/>
			<Field Get="true" Name="spriteIndex" Set="false" Type="Asset.GMSprite"/>
			<Field Get="true" Name="texture" Set="false" Type="Asset.GMTexturePage"/>
			<Field Get="true" Name="name" Set="false" Type="String"/>
			<Field Get="true" Name="bold" Set="false" Type="Bool"/>
			<Field Get="true" Name="italic" Set="false" Type="Bool"/>
			<Field Get="true" Name="glyphs" Set="false" Type="Struct"/>
		</Structure>
		<Structure Name="FontInfoGlyph">
			<Field Get="true" Name="char" Set="false" Type="Real"/>
			<Field Get="true" Name="x" Set="false" Type="Real"/>
			<Field Get="true" Name="y" Set="false" Type="Real"/>
			<Field Get="true" Name="w" Set="false" Type="Real"/>
			<Field Get="true" Name="h" Set="false" Type="Real"/>
			<Field Get="true" Name="shift" Set="false" Type="Real"/>
			<Field Get="true" Name="offset" Set="false" Type="Real"/>
			<Field Get="true" Name="kerning" Set="false" Type="Array"/>
		</Structure>
		<Structure Name="Exception">
			<Field Get="true" Name="message" Set="true" Type="String">此异常的短消息。</Field>
			<Field Get="true" Name="longMessage" Set="true" Type="String">此异常的长消息。</Field>
			<Field Get="true" Name="script" Set="true" Type="String">描述引发此异常的脚本。</Field>
			<Field Get="true" Name="stacktrace" Set="true" Type="Array.String">从中生成异常的堆栈帧。</Field>
		</Structure>
		<Structure FeatureFlag="audio-fx" Name="AudioBus">
			<Field Get="true" Name="bypass" Set="true" Type="Bool">是否绕过总线的所有效果和增益缩放。</Field>
			<Field Get="true" Name="gain" Set="true" Type="Real">总线的输出增益。</Field>
			<Field Get="true" Name="effects" Set="true" Type="Array.Struct.AudioEffect">总线上的音响效果链</Field>
		</Structure>
		<Structure FeatureFlag="audio-fx" Name="AudioEffect">
			<Field Get="true" Name="bypass" Set="true" Type="Bool">是否绕过该效果。</Field>
		</Structure>
	</Structures>
	<Enumerations>
		<Enumeration Name="AudioEffectType">
			<Member Deprecated="false" Name="Bitcrusher" Value="0">通过降低带宽使声音失真。</Member>
			<Member Deprecated="false" Name="Delay" Value="1"/>
			<Member Deprecated="false" Name="Gain" Value="2"/>
			<Member Deprecated="false" Name="HPF2" Value="3">高通滤波器</Member>
			<Member Deprecated="false" Name="LPF2" Value="4">低通滤波器</Member>
			<Member Deprecated="false" Name="Reverb1" Value="5">混响，回声。</Member>
		</Enumeration>
	</Enumerations>
</GameMakerLanguageSpec>