		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_current_frame" Set="false" Type="Real">这个全局变量包含network tick，可以在回滚网络中代替时钟时间使用</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_confirmed_frame" Set="false" Type="Real">这个全局变量包含帧数，我们已经为所有玩家确认了输入</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_event_id" Set="false" Type="Real">这个全局变量包含最后触发的事件id</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_event_param" Set="false" Type="Asset.GMObject">这个全局变量包含一个结构，该结构带有最后一个被触发事件的参数</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_game_running" Set="false" Type="Bool">如果游戏正在运行，这个全局变量包含标志</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="rollback_api_server" Set="false" Type="String">这个全局变量包含gx游戏API url</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_id" Set="false" Type="Real">这标识了该实例属于回滚网络系统中的哪个玩家。</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_local" Set="false" Type="Bool">这标识该实例是否属于回滚网络系统中的本地播放器。</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_avatar_url" Set="false" Type="String">在Opera GX中与此玩家相关联的头像的URL，用于回滚联网。</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_avatar_sprite" Set="false" Type="Asset.GMSprite">在Opera GX中，与此玩家相关联的头像精灵，用于回滚联网。</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_type" Set="false" Type="String">这标识该实例属于回滚网络系统中的来宾帐户还是用户帐户。</Variable>
		<Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="true" Name="player_user_id" Set="false" Type="String">这是回滚网络系统中Opera GX的用户id。</Variable>
	</Variables>
	<Constants>
		<Constant Name="$$implicit_argument$$" Type="Undefined"/>
		<Constant Class="AssetType" Deprecated="false" Name="asset_object" Type="Real">给定的名称引用了一个对象。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_sprite" Type="Real">给定的名称引用了一个精灵。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_sound" Type="Real">给定的名称引用了一个声音。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_room" Type="Real">给定的名称引用了一个房间。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_tiles" Type="Real">给定的名称引用了一个图块集。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_path" Type="Real">给定的名称引用了一个路径。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_script" Type="Real">给定的名称引用了一个脚本。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_font" Type="Real">给定的名称引用了一种字体。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_timeline" Type="Real">给定的名称引用了时间线。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_shader" Type="Real">给定的名称引用了一个着色器。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_animationcurve" Type="Real">给定的名称引用了动画曲线。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_particlesystem" Type="Real">给定的名称指的是粒子系统。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_sequence" Type="Real">给定的名称引用了一个序列。</Constant>
		<Constant Class="AssetType" Deprecated="false" Name="asset_unknown" Type="Real">给定的名称指的是不存在的资源，或者不是上面列出的资源之一。</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_exponent_distance" Type="Real"> 增益=(侦听器的距离/基准距离)^(-衰减系数) gain = (listener_distance / reference_distance) ^ (-falloff_factor)</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_exponent_distance_clamped" Type="Real"> 距离=夹逼(侦听器的距离，基准距离，最远距离) ,增益=(距离/基准距离)^-衰减系数。distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (distance / reference_distance) ^ (-falloff_factor)</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_exponent_distance_scaled" Type="Real"> 距离=夹逼(侦听器的距离，基准距离，最远距离) ,增益=(距离/基准距离)^(-衰减系数)*(((最远距离-距离)/(最远距离-基准距离)^(距离/最远距离))。distance = clamp(listener_distance, reference_distance, maximum_distance) gain = ((distance / reference_distance) ^ (-falloff_factor)) * (((maximum_distance - distance) / (maximum_distance - reference_distance)) ^ (distance / maximum_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_inverse_distance" Type="Real"> gain = 基准距离 / (基准距离 + 衰减系数 * (侦听器的距离 - 基准距离)) gain = reference_distance / (reference_distance + falloff_factor * (listener_distance - reference_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_inverse_distance_clamped" Type="Real"> 距离 = 夹逼(侦听器的距离, 基准距离, 最远距离) 增益 = 基准距离 / (基准距离 + 衰减系数 * *(距离-基准距离) distance = clamp(listener_distance, reference_distance, maximum_distance) gain = reference_distance / (reference_distance + falloff_factor * (distance - reference_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_inverse_distance_scaled" Type="Real"> 距离=夹逼(侦听器的距离，基准距离，最远距离)增益 = (基准距离 / (基准距离 + 衰减系数 * (距离 - 基准距离))) * (((最远距离 - 距离) / (最远距离 - 基准距离)) ^ (距离 / 最远距离)) distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (reference_distance / (reference_distance + falloff_factor * (distance - reference_distance))) * (((maximum_distance - distance) / (maximum_distance - reference_distance)) ^ (distance / maximum_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_linear_distance" Type="Real"> 距离=最小(距离, 最大距离)增益=(1-衰减系数*(距离-基准距离)/(最远距离-基准距离) distance = min(distance, maximum_distance) gain = (1 - falloff_factor * (distance - reference_distance) / (maximum_distance - reference_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_linear_distance_clamped" Type="Real"> 距离=夹逼(侦听器的距离，基准距离，最远距离)增益=(1-衰减系数*(距离-基准距离)/(最远距离-基准距离) distance = clamp(listener_distance, reference_distance, maximum_distance) gain = (1 - falloff_factor * (distance - reference_distance) / (maximum_distance - reference_distance))</Constant>
		<Constant Class="AudioFalloff" Deprecated="false" Name="audio_falloff_none" Type="Real"> 增益 = 1</Constant>
