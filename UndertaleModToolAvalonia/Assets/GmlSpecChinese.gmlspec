			<Parameter Name="y1" Optional="false" Type="Real">圆角矩形顶部的y坐标。</Parameter>
			<Parameter Name="x2" Optional="false" Type="Real">圆角矩形右侧的x坐标。</Parameter>
			<Parameter Name="y2" Optional="false" Type="Real">圆角矩形底部的y坐标。</Parameter>
			<Parameter Name="col1" Optional="false" Type="Constant.Color">中心的颜色。</Parameter>
			<Parameter Name="col2" Optional="false" Type="Constant.Color">外边缘颜色。</Parameter>
			<Parameter Name="outline" Optional="false" Type="Bool">矩形是轮廓(true)还是填充(false)。</Parameter>
		</Function>
		<Function Deprecated="false" Locale="GB" Name="draw_roundrect_colour_ext" Pure="true" ReturnType="Undefined">
			<Description>使用此函数，您可以绘制圆角矩形或填充圆角矩形的轮廓，其中(x1,y1)位置是左上角，(x2,y2)位置是右下角。如果矩形被填充，那么颜色参数将用于生成从中心到边缘的颜色渐变，其中颜色1是中心颜色，颜色2是边缘颜色。您还必须提供x轴和y轴的半径值(以像素为单位)，角将按这些值圆化。可以使用draw_set_circle_precision()函数定义绘制角的精确度。使用此函数，您可以绘制矩形或填充矩形的轮廓，其中(x1,y1)位置是左上角，(x2,y2)位置是右下角。</Description>
			<Parameter Name="x1" Optional="false" Type="Real">圆角矩形左侧的x坐标。</Parameter>
			<Parameter Name="y1" Optional="false" Type="Real">圆角矩形顶部的y坐标。</Parameter>
			<Parameter Name="x2" Optional="false" Type="Real">圆角矩形右侧的x坐标。</Parameter>
			<Parameter Name="y2" Optional="false" Type="Real">圆角矩形底部的y坐标。</Parameter>
			<Parameter Name="xrad" Optional="false" Type="Real">从矩形角到x轴的曲线的半径。</Parameter>
			<Parameter Name="yrad" Optional="false" Type="Real">曲线的半径沿y轴从矩形的角。</Parameter>
			<Parameter Name="col1" Optional="false" Type="Constant.Color">中心的颜色。</Parameter>
			<Parameter Name="col2" Optional="false" Type="Constant.Color">外边缘颜色。</Parameter>
			<Parameter Name="outline" Optional="false" Type="Bool">矩形是轮廓(true)还是填充(false)。</Parameter>
		</Function>
		<Function Deprecated="false" Name="draw_roundrect_ext" Pure="true" ReturnType="Undefined">
