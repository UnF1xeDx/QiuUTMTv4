		<Function Deprecated="false" Name="string_concat" Pure="true" ReturnType="String">
			<Description>此函数连接一组参数，非字符串值将被转换为字符串。</Description>
			<Parameter Name="..." Optional="false" Type="ArgumentIdentity">这些值被连接起来。</Parameter>
		</Function>
		<Function Deprecated="false" Name="string_concat_ext" Pure="true" ReturnType="String">
			<Description>此函数连接数组中的一系列元素，非字符串值将被转换为字符串。</Description>
			<Parameter Name="values_array" Optional="false" Type="Array">要连接的值数组。</Parameter>
