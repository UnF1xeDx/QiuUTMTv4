		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_get_input" Pure="false" ReturnType="Struct">
			<Description>此函数返回一个struct，包含字段w,a,s,d,z,x,c,space,up,left,down,right和对应的last_？最后一帧输入的字段。</Description>
