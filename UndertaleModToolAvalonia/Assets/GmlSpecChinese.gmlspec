			<Parameter Name="y2" Optional="false" Type="Real">在网格中区域底部的位置。</Parameter>
			<Parameter Name="val" Optional="false" Type="ArgumentIdentity">要添加到区域单元格中的值。</Parameter>
		</Function>
		<Function Deprecated="false" Name="ds_grid_clear" Pure="false" ReturnType="Undefined">
			<Description>此函数可用于将给定的DS网格清除到特定值。网格中的所有单元格都将包含此值，该值可以是实数或字符串。下图说明了这是如何工作的:</Description>
			<Parameter Coerce="true" Name="index" Optional="false" Type="Id.DsGrid">要清除的网格的索引。</Parameter>
