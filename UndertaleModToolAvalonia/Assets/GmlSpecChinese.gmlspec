			<Parameter Name="to" Optional="true" Type="Real">消息发送到的player。如果不指定，消息将会发送给游戏中的每个人。</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_use_player_prefs" Pure="false" ReturnType="Undefined">
			<Description>此函数用于启用玩家偏好，需要在加入或创建回滚游戏前调用。当使用此函数时，游戏不会自动启动，而是需要在所有玩家都设置好偏好后调用rollback_start_game。</Description>
			<Parameter Name="default" Optional="true" Type="Any">默认玩家偏好</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_set_player_prefs" Pure="false" ReturnType="Undefined">
			<Description>此函数用于更新本地玩家偏好。只能在加入或创建游戏之后，但在开始游戏之前设置首选项。</Description>
			<Parameter Name="default" Optional="false" Type="Any">玩家偏好</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_get_player_prefs" Pure="false" ReturnType="Any">
			<Description>此函数用于获取给定玩家的偏好。如果没有设置首选项，将返回Undefined。如果没有给定玩家id参数，将返回本地玩家的首选项。</Description>
			<Parameter Name="player id" Optional="true" Type="Real">玩家id</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_get_info" Pure="false" ReturnType="Struct">
			<Description>此函数返回一个包含玩家名字和头像url的结构。</Description>
			<Parameter Name="player_id" Optional="true" Type="Real">要获取其信息的玩家id</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_use_random_input" Pure="false" ReturnType="Undefined">
			<Description>此函数在同步测试中为其他玩家切换随机输入。</Description>
			<Parameter Name="enabled" Optional="false" Type="Bool">在同步测试中为其他玩家启用随机输入的标志</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_display_events" Pure="false" ReturnType="Undefined">
			<Description>此函数设置是否应该使用回滚事件的默认显示。默认值为true。</Description>
			<Parameter Name="enabled" Optional="false" Type="Bool">启用事件默认显示的标志</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_sync_on_frame" Pure="false" ReturnType="Bool">
			<Description>在当前帧上同步回滚游戏。这意味着，只有在所有输入都得到确认的情况下，我们才会继续越过当前帧。如果成功，则返回true如果将重新运行当前帧，则返回false。</Description>
		</Function>
		<Function Deprecated="false" Name="time_source_create" Pure="true" ReturnType="Id.TimeSource">
			<Description>创建新的时间源，返回其索引。</Description>
			<Parameter Name="parent" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的父级</Parameter>
			<Parameter Name="period" Optional="false" Type="Real">时间源的周期</Parameter>
			<Parameter Name="units" Optional="false" Type="Constant.TimeSourceUnits">衡量周期的单位</Parameter>
			<Parameter Name="callback" Optional="false" Type="Function">时间源过期时要调用的回调</Parameter>
			<Parameter Name="args" Optional="true" Type="Array">要传递给回调的参数</Parameter>
			<Parameter Name="reps" Optional="true" Type="Real">时间源应该执行的重复次数</Parameter>
			<Parameter Name="expiry_type" Optional="true" Type="Constant.TimeSourceExpiryType">时间源的到期类型</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_destroy" Pure="false" ReturnType="Undefined">
			<Description>破坏时间源，只要它没有子级。</Description>
