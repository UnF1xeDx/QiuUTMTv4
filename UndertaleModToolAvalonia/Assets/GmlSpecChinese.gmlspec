			<Parameter Name="..." Optional="true" Type="ArgumentIdentity">要插入的值</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_length" Pure="true" ReturnType="Real">
			<Description>通过此函数，您可以获得数组维度的长度(条目的数量)。您提供数组索引值，函数将返回一个整数值，表示数组包含的条目数量。此函数也可以用于多维数组，只要你在提供数组索引时指定你想获取哪个维度的长度，遵循以下模式:</Description>
			<Parameter Name="array" Optional="false" Type="Array">要检查的数组的索引。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_pop" Pure="false" ReturnType="ArgumentIdentity">
