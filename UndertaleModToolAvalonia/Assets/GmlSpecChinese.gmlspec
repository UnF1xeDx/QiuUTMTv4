			<Parameter Name="length" Optional="true" Type="Real">应该置乱多少个条目。默认为array_length() - 1。</Parameter>
		</Function>
		<Function Deprecated="false" Name="array_shuffle_ext" Pure="false" ReturnType="Undefined">
