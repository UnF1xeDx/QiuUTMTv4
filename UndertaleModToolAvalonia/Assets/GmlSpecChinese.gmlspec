			<Parameter Name="binfile" Optional="false" Type="Id.BinaryFile">要从中获取数据的文件的ID。</Parameter>
		</Function>
		<Function Deprecated="false" Name="file_bin_rewrite" Pure="false" ReturnType="Undefined">
			<Description>此函数获取函数file_bin_open()返回的文件名句柄，然后重写文件，清除所有以前的数据，从文件的开头开始写。</Description>
			<Parameter Name="binfile" Optional="false" Type="Id.BinaryFile">要重写的文件的ID。</Parameter>
		</Function>
		<Function Deprecated="false" Name="file_bin_seek" Pure="false" ReturnType="Undefined">
			<Description>此函数将文件中的当前读取位置移动到指定位置。您提供文件ID值，由函数file_bin_open()返回，为了追加文件，在写入之前将位置移动到文件的大小。</Description>
			<Parameter Name="binfile" Optional="false" Type="Id.BinaryFile">要读取的文件的ID。</Parameter>
