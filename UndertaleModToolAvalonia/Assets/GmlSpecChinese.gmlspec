			<Parameter Name="destroy_tree" Optional="true" Type="Bool">是否也要销毁时间源的所有子级</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_start" Pure="false" ReturnType="Undefined">
			<Description>启动/恢复时间源及其所有子源。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_stop" Pure="false" ReturnType="Undefined">
			<Description>停止时间源及其所有子级。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_pause" Pure="false" ReturnType="Undefined">
			<Description>暂停时间源及其所有子级。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_resume" Pure="false" ReturnType="Undefined">
			<Description>恢复一个时间源及其所有子级。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_reset" Pure="false" ReturnType="Undefined">
			<Description>重置时间源及其所有子节点。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_reconfigure" Pure="false" ReturnType="Undefined">
			<Description>重置和重新配置时间源。另外，重置所有时间源的子级。 </Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
			<Parameter Name="period" Optional="true" Type="Real">时间源的周期</Parameter>
			<Parameter Name="units" Optional="true" Type="Constant.TimeSourceUnits">衡量周期的单位</Parameter>
			<Parameter Name="callback" Optional="true" Type="Function">时间源过期时要调用的回调</Parameter>
			<Parameter Name="args" Optional="true" Type="Array">要传递给回调的参数</Parameter>
			<Parameter Name="reps" Optional="true" Type="Real">时间源应该执行的重复次数</Parameter>
			<Parameter Name="expiry_type" Optional="true" Type="Constant.TimeSourceExpiryType">时间源的到期类型</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_period" Pure="true" ReturnType="Real">
			<Description>返回时间源的周期，以其自身的单位度量。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_reps_completed" Pure="true" ReturnType="Real">
			<Description>返回时间源到目前为止已完成的重复次数。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_reps_remaining" Pure="true" ReturnType="Real">
			<Description>返回时间源还未完成的重复次数。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_units" Pure="true" ReturnType="Constant.TimeSourceUnits">
			<Description>返回时间源的度量单位。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_time_remaining" Pure="true" ReturnType="Real">
			<Description>返回时间源下一次到期前剩下的时间，以其自身的单位度量。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_state" Pure="true" ReturnType="Constant.TimeSourceState">
			<Description>返回时间源的当前活动状态。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_parent" Pure="true" ReturnType="Id.TimeSource">
			<Description>返回此时间源的父对象的索引。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_get_children" Pure="true" ReturnType="Array[Id.TimeSource]">
			<Description>返回一个数组，该数组包含此时间源的所有子对象的索引。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_source_exists" Pure="true" ReturnType="Bool">
			<Description>如果给定的索引对应于现有的时间源，则返回true。</Description>
			<Parameter Name="id" Optional="false" Type="Id.TimeSource,Constant.TimeSource">时间源的索引</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_seconds_to_bpm" Pure="true" ReturnType="Real">
			<Description>将以秒为单位的周期转换为以拍每分钟为单位的等效频率。</Description>
			<Parameter Name="seconds" Optional="false" Type="Real">要转换的值</Parameter>
		</Function>
		<Function Deprecated="false" Name="time_bpm_to_seconds" Pure="true" ReturnType="Real">
			<Description>将频率(以每分钟为单位)转换为其等效周期(以秒为单位)。</Description>
			<Parameter Name="bpm" Optional="false" Type="Real">要转换的值</Parameter>
		</Function>
		<Function Deprecated="false" Name="call_later" Pure="true" ReturnType="Id.TimeSource">
			<Description>在指定的时间后调用回调。返回可用于取消调用的句柄。</Description>
			<Parameter Name="period" Optional="false" Type="Real">在调用回调之前要等待多长时间</Parameter>
			<Parameter Name="units" Optional="false" Type="Constant.TimeSourceUnits">衡量周期的单位</Parameter>
			<Parameter Name="callback" Optional="false" Type="Function">要调用的回调</Parameter>
			<Parameter Name="repeat" Optional="true" Type="Bool">这种情况是否应该无限重复</Parameter>
		</Function>
		<Function Deprecated="false" Name="call_cancel" Pure="false" ReturnType="Undefined">
			<Description>取消由call_later设置的延迟调用。</Description>
			<Parameter Name="handle" Optional="false" Type="Id.TimeSource">取消调用的句柄</Parameter>
		</Function>
	</Functions>
	<Variables>
		<Variable Deprecated="false" Get="true" Instance="false" Name="font_texture_page_size" Set="true" Type="Real">当使用函数font_add()时，这个内置变量可以用来获取或设置纹理页面大小。在使用此函数添加字体时，GameMaker将创建所需字形的纹理页面缓存，其大小由该变量定义。流程如下:</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="instance_count" Set="false" Type="Real">使用这个只读变量，您可以获得房间中所有活动实例的计数。这将包括运行代码的实例，但不包括那些已使用实例停用函数停用的实例。注意，这个变量只会在步骤开始时给出实例的数量，因此在步骤启动后对房间中实例的任何更改都不会被考虑在内。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="instance_id" Set="false" Type="Array[Id.Instance]">这个只读数组保存房间中每个活动实例的所有id。这意味着，如果您使用了任何实例取消激活函数，那么已经取消激活的实例将不会包含在该数组中(如果您以前使用了该数组中的值，那么它现在将返回关键字noone)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="alarm" Set="true" Type="Array[Real]">这个一维数组用于获取实例可能具有的任何告警的当前值，也可以用于设置这些告警。在对象的每个实例中内置了12个警报，每个警报都有自己的事件，当该变量达到0时将运行该事件。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="depth" Set="true" Type="Real">当你创建一个对象时，你可以为它分配一个初始深度，这将定义当游戏正在进行时，该对象的实例将如何在房间中绘制，这个变量可以用于在游戏运行时获取和更改深度值。通常不需要使用这个变量，因为您应该将实例添加到离散层中，而离散层又被设置为特定的深度，但是您可能希望使用这个值更改实例的深度，在这种情况下，将专门为具有给定深度的实例创建一个&quot;临时层&quot;。注意，当没有实例在相同的深度上时，这个临时层将从内存中删除(不像常规层，即使它们上面没有任何东西也会保留)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="direction" Set="true" Type="Real">GameMaker中的所有实例都有特定的&quot;内置&quot;属性，你可以使用和设置这些属性来控制它们的外观和行为。Direction是其中一个属性，可以用来设置实例的移动方向，当实例的速度不是0时。注意，GameMaker中的方向通常计算为0°为右，90°为上，180°为左，270°为下，重力和gravity_direction变量可以在游戏中使用时修改方向值。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="friction" Set="true" Type="Real">摩擦是实例可以拥有的&quot;内置&quot;属性之一，可以用来随着时间的推移减慢实例的速度，当速度不是0时。它的工作原理很简单，就是每一步从速度中减去一个量，直到物体的速度为0，所以如果将摩擦设置为0.1，实例的速度为1(每一步1像素)，它将在经过10步后减速并停止。还要注意的是，摩擦力同样作用于正速度和负速度，最终的结果总是物体在给定时间后的速度为0。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="gravity" Set="true" Type="Real">Gravity是所有实例都具有的&quot;内置&quot;变量之一，设置后将在实例的gravity_direction上施加恒定的力，从而影响实例的速度和方向。注意，重力是一个累积力，如果你选择不限制最终速度，它会加速物体，通常你会将这个变量设置为小数，如0.01。如果将重力设置为0，则不会将重力应用到实例(这是默认值)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="gravity_direction" Set="true" Type="Real">Gravity_direction是所有实例都具有的&quot;内置&quot;属性之一，可用于在实例gravity大于0时设置移动方向。注意，GameMaker中的方向通常以0°为右，90°为上，180°为左，270°为下来计算。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="hspeed" Set="true" Type="Real">Hspeed是所有实例都具有的&quot;内置&quot;属性之一，它定义了实例的水平移动速度(沿x轴)，单位为每一步像素。所以，hspeed为3意味着每一步向右移动3个像素(+x)，而hspeed为-3则意味着每一步向左移动3个像素(-x)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="id" Set="false" Type="Id.Instance">这个只读变量保存实例的唯一标识号。您创建的每个实例——无论是通过代码还是通过在room Editor中将它们添加到房间中——都有一个编号，用于在内部标识该实例，变量id是您可以用来引用它的。当使用instance_create_layer()或instance_create_depth()以及其他实例函数创建实例时，id也会返回(并且可以存储在变量中)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="layer" Set="true" Type="Id.Layer">该内置变量是为房间中的每个实例创建的，包含实例所分配到的层的层ID值。然后，这个值可以用于其他函数，如layer_get_depth()，或者可以更改它以将实例移动到另一个层，但注意，如果正在分配的层在当前房间中不存在，那么您将会得到一个错误，该错误将强制您的游戏关闭。指定层时，必须提供由函数layer_get_id()返回的唯一层id(使用命名的房间层时)，或由函数layer_create()返回的唯一层ID(在运行时创建自己的层时)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="persistent" Set="true" Type="Bool">可以读取该变量，以确定实例是否被标记为持久，或者可以使用该变量将实例的持久性设置为true(持久)或false(非持久)。一个持久的实例是一个将从一个房间&quot;带到&quot;另一个房间的实例，这意味着(例如)它只需在游戏开始时创建一次，并且它将出现在所有其他房间中。应该注意持久性，因为很容易失去对持久性实例的跟踪，这可能会在游戏开发的后期导致问题。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="solid" Set="true" Type="Bool">通过对象编辑器中的对象属性，或者通过更改此内置变量的值，可以将实例标记为实体。如果将solid设置为true，则当检测到碰撞时，碰撞实例会自动返回到碰撞前一步中的位置(然后在碰撞事件中运行任何代码或操作)。如果设置为false，所有定位都必须通过碰撞事件来处理。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="speed" Set="true" Type="Real">GameMaker中的所有实例都有特定的&quot;内置&quot;属性，你可以使用和设置这些属性来控制它们的外观和行为。速度是这些属性之一，它定义了实例每移动一步将移动多少像素。与hspeed和vspeed不同，speed没有关联的方向，因为它由实例的方向值控制，但它可以有负值，在这种情况下，实例将沿与方向函数设置的方向相反的方向移动(即:方向- 180)。注意，设置速度和/或方向也会修改hspeed和vspeed变量的值，并且重力、重力方向和摩擦力在游戏中使用时都会修改该变量的值。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="visible" Set="true" Type="Bool">通过将此变量设置为true(可见)或false(不可见)，可以将实例标记为可见或不可见。这是通过告诉GameMaker跳过这个实例的draw事件来实现的，所以在使用时必须小心，因为这意味着当实例不可见时，放置在draw事件中的任何代码都不会运行。另注意，如果实例所分配到的层被标记为不可见，则将此变量设置为true将不起作用，直到该层本身也被标记为可见。</Variable>
        <Variable Deprecated="false" FeatureFlag="rollback" Get="true" Instance="false" Name="managed" Set="false" Type="Bool">此只读变量指示该对象是否由回滚多人游戏系统管理。</Variable>
        <Variable Deprecated="false" Get="true" Instance="true" Name="vspeed" Set="true" Type="Real">vspeed是所有实例都具有的&quot;内置&quot;属性之一，它定义了实例的垂直移动速度(沿y轴),单位为每步像素。因此，vspeed为3意味着每步向底部(+y)移动3个像素，vspeed为-3意味着每步向顶部(-y)移动3个像素。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="x" Set="true" Type="Real">实例的x值是当前房间中的水平位置，以像素为单位。该值可以是0、正数或负数，其中0是房间的左侧，向右移动增加x，向左移动减少x(x的负值意味着实例已经超出了房间的左侧)。你甚至可以给x一个实数值，比如12.345，但是由于你不能得到一个像素的0.345，这个实例可能看起来没有移动，尽管这些值将被GameMaker内部维护和使用，并且完全有效。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="xprevious" Set="true" Type="Real">这个内置变量返回实例的前一个x位置。该变量将在begin step事件开始之前设置，但也可以在任何时候通过代码设置，这意味着如果有必要，您可以给它自己的自定义值。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="xstart" Set="true" Type="Real">此变量存储实例在房间中首次创建时的初始x位置。这不是一个只读变量，可以设置和读取。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="y" Set="true" Type="Real">实例的y值是当前房间中的垂直位置，以像素为单位。该值可以是0、正数或负数，其中0是房间的顶部，向下移动增加y，向上移动减少y(y的负值表示实例已经超出房间的顶部)。你甚至可以给y一个实数值，比如12.345，但是由于你不能得到一个像素的0.345，实例可能看起来没有移动，尽管这些值将由GameMaker内部维护和使用，并且完全有效。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="yprevious" Set="true" Type="Real">这个内置变量返回实例的前一个y位置。这个变量将在begin step事件开始之前被设置为当前的x位置，但是它也可以在任何时候通过代码来设置，这意味着如果有必要的话，您可以给它自己的自定义值。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="ystart" Set="true" Type="Real">此变量存储实例在房间中首次创建时的初始y位置。这不是一个只读变量，可以设置和读取。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="object_index" Set="false" Type="Asset.GMObject">这个只读变量返回创建实例的对象的索引。这与对象名称不同，对象名称是一个字符串，可以使用object_get_name()找到，因为此函数返回索引号，这是GameMaker在创建时分配给每个对象的唯一值。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="event_number" Set="false" Type="Constant.EventNumber">这个只读变量返回当前正在调用的事件的编号，其中该编号实际上是指事件的&quot;子事件&quot;,即:对于step事件，事件编号可以是常量ev_step_normal、ev_step_begin或ev_step_end中的任何一个。有关特定子事件可用的常量的完整列表，请参见event_perform()，如果您需要知道主事件本身，您应该检查event_type。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="event_object" Set="false" Type="Asset.GMObject">这个只读变量返回运行被检查事件的实例的对象索引。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="event_type" Set="false" Type="Constant.EventType">此只读变量返回当前正在执行的事件类型，可以是下列常量之一:</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_endaction" Set="true" Type="Constant.PathAction">此变量可用于获取或更改实例到达当前路径末尾时的反应。通常你会在使用path_start()启动路径时设置这个，但是你可能希望根据游戏中的事件数量来改变这个行为。可用值使用以下常量表示:</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="path_index" Set="false" Type="Asset.GMPath">GameMaker中的所有资源都有一个唯一的标识号，path_index是一个只读变量，它保存使用path_start()函数分配给实例的给定路径资源的索引值。如果实例没有分配路径，变量将被设置为-1。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_orientation" Set="true" Type="Real">该变量保存调用函数path_start()时分配给实例的路径的当前方向。创建路径时，它的方向是默认的0度，但是您可以使用它将这个值设置为您想要的任何值。请记住，在GameMaker中(除非您使用物理)，角度是逆时针计算的，因此将路径方向设置为90°会将路径向左旋转。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_position" Set="true" Type="Real">此函数可用于获取或设置实例在路径上的位置。该值是从0到1的标准化值，因此如果将其设置为0.5，实例将被移动到路径的正中间。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_positionprevious" Set="true" Type="Real">该变量可用于获取或设置实例在上一步中沿其当前路径的位置，是一个介于0和1之间的标准化值，即:0是路径的起始位置，1是结束位置。它的工作方式类似于xprevious和yprevious变量，只是它特定于路径。如果有什么东西挡住了去路，这对于临时停止路径跟随器是很有用的(参见下面的示例代码)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_scale" Set="true" Type="Real">该值可用于获取或设置实例当前分配路径的比例(由函数path_start()设置)，默认值为1。这是一个标量值，因此1是1:1的比例，例如，将其设置为2将是比例的两倍，而将其设置为0.5将是比例的一半。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="path_speed" Set="true" Type="Real">在使用函数path_start()启动路径后，可以使用此函数获取或设置路径的速度。您可以使用负值来表示实例应该沿相反的路径前进。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room" Set="true" Type="Asset.GMRoom">这个变量保存了你的游戏正在运行的当前房间的房间索引。这不是一个只读变量，但是更改它不会更改当前房间的索引值，而是会更改房间以匹配您已设置变量的索引。这样做的时候要小心，如果你改变变量的索引无效，游戏会抛出一个错误并关闭。一般来说，更好的做法是使用room_goto()来改变房间。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room_first" Set="false" Type="Asset.GMRoom">这个只读变量返回游戏中第一个房间的索引(这是由房间在房间管理器中出现的顺序定义的，而不是由它们被创建的顺序定义的)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room_height" Set="true" Type="Real">该变量以像素为单位保存当前房间的高度。您可以随时更改此变量来更改房间的高度，更改将应用于房间的底部，因为原点被认为是左上角。例如，如果房间的高度为480像素，而您将其设置为640像素，则房间将向下扩展，底部增加180像素。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room_last" Set="false" Type="Asset.GMRoom">这个只读变量返回游戏中最后一个房间的索引(这是由房间在房间管理器中出现的顺序定义的，而不是由它们被创建的顺序定义的)。注意，该变量不会识别或考虑使用room_add()或room_duplicate()动态添加的房间。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room_persistent" Set="true" Type="Bool">该变量可用于获取和设置当前房间的永久标志。如果设置为true，则该房间被认为是持久的，在这种情况下，每次您离开房间并再次回来时，该房间内实例的状态都将被保持。然而，如果它被标记为false，每次你回到房间，它将被重置为其初始状态。你应该注意到永久房间比普通房间占用更多的内存，不建议在你的游戏中有太多的永久房间。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="room_width" Set="true" Type="Real">这个变量保存当前房间的宽度(以像素为单位)。你可以在任何时候改变这个变量来改变房间的宽度。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="in_sequence" Set="true" Type="Bool">这是一个内置变量，是为游戏中每个对象实例创建的实例变量的一部分。如果实例由序列控制，该变量将返回true，否则将返回false。这是一个只读变量，不能更改。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sequence_instance" Set="false" Type="Struct.SequenceInstance">这是一个内置变量，是为游戏中每个对象实例创建的实例变量的一部分。如果实例由序列控制，此变量将保存控制该实例的sequence的序列实例结构，否则将为未定义。这是一个只读变量，不能更改。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="drawn_by_sequence" Set="true" Type="Bool">这是一个内置变量，是为游戏中每个对象实例创建的实例变量的一部分。这可以在任何时候更改，但只会影响由序列控制的实例的行为。在本例中，如果该变量设置为true，则序列将处理实例的绘制顺序，否则将发生正常的实例绘制。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="bbox_bottom" Set="false" Type="Real">这个只读变量返回实例的边界框底部的y位置(在房间内)，其中边界框由实例的掩码的最大宽度和高度定义(由sprite_index或mask_index设置)。即使精灵有一个精确的碰撞掩码，边界框仍然存在，并用于某些事情，所以你可以使用这个变量来找到它。注意，当实例没有分配精灵时，返回值将与实例Y位置相同。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="bbox_left" Set="false" Type="Real">这个只读变量返回实例的左侧边界框的位置(沿x轴)，其中边界框由实例的掩码的最大宽度和高度定义(由sprite_index或mask_index设置)。即使精灵有一个精确的碰撞掩码，边界框仍然存在，并用于某些事情，所以你可以使用这个变量来找到它。注意，当实例没有分配精灵时，返回值将与实例X位置相同。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="bbox_right" Set="false" Type="Real">这个只读变量返回实例的边界框右侧在房间内(沿x轴)的位置，其中边界框由实例的掩码的最大宽度和高度定义(由sprite_index或mask_index设置)。即使精灵有一个精确的碰撞掩码，边界框仍然存在，并用于某些事情，所以你可以使用这个变量来找到它。注意，当实例没有分配精灵时，返回值将与实例X位置相同。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="bbox_top" Set="false" Type="Real">这个只读变量返回实例的边界框顶部在房间内(沿y轴)的位置，其中边界框由实例的掩码的最大宽度和高度定义(由sprite_index或mask_index设置)。即使精灵有一个精确的碰撞掩码，边界框仍然存在，并用于某些事情，所以你可以使用这个变量来找到它。注意，当实例没有分配精灵时，返回值将与实例Y位置相同。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_alpha" Set="true" Type="Real">该变量用于获取或设置精灵的透明度(Alpha)值。Alpha总是计算为0到1之间的值，其中0是完全透明的，1是完全不透明的。注意，为了使这个变量的变化可见，实例应该没有绘制事件(所以GameMaker将默认绘制精灵)，或者使用一个扩展的绘制函数(如draw_self()或draw_sprite_ext())绘制。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_angle" Set="true" Type="Real">这个值设置了精灵的角度(旋转)，以角度来衡量，右为0º，上为90º，左为180º，下为270º。将此变量设置为0将重置要绘制的精灵，就像在精灵编辑器中定义的那样。注意，为了使这个变量的变化可见，实例应该没有绘制事件(所以GameMaker将默认绘制精灵)，或者使用一个扩展的绘制函数(如draw_self()或draw_sprite_ext())绘制。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_blend" Set="true" Type="Constant.Color">这个变量控制实例精灵的&quot;着色&quot;，默认值是-1(也可以是c_white)。任何其他值(包括内部颜色常量，如c_red或c_aqua)会将指定的颜色与原始精灵混合。注意，为了使这个变量的变化可见，实例应该没有绘制事件(所以GameMaker将默认绘制精灵)，或者使用一个扩展的绘制函数(如draw_self()或draw_sprite_ext())绘制。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_index" Set="true" Type="Real">精灵由一个或多个子图像组成，当它们从一个切换到另一个时，这些子图像可以使精灵看起来有动画效果，或者它们可以在代码中切换以提供不同的&quot;状态&quot;，就像窗口中的按钮一样。如果精灵是动画，那么你可以通过检查image_index变量来获得动画的当前帧，或者如果你想改变静态精灵的状态，你可以通过设置这个变量来选择一个新的子图像。注意，要使该变量的变化可见，实例要么没有绘制事件(所以GameMaker将默认绘制精灵)，要么使用绘制函数之一绘制，如draw_self()或draw_sprite_ext()(通过向适当的参数提供image_index)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_number" Set="false" Type="Real">这个只读变量可用于获取已分配给实例的精灵中的子图像数量(如果您需要为一个非分配给实例的精灵获取子图像数量，则应该使用sprite_get_number()))。注意，当有(例如)一个子图像时，该变量将返回&quot;1&quot;，但该子图像的image_index为0。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_speed" Set="true" Type="Real">这个变量决定了GameMaker在当前实例精灵的子图像中循环的速度。给定的速度值是一个乘数，1是默认值，设置为0.5将使动画速度减半(就像在精灵编辑器或图像编辑器中设置的那样)，而设置为2将使动画速度翻倍。如果使用的精灵没有子图像，这个变量将没有效果。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_xscale" Set="true" Type="Real">该值设置应用于已分配给当前实例的精灵的水平缩放。1的比例表示不能缩放(1:1)，较小的值将缩小(例如，0.5将是精灵宽度的一半)，较大的值将扩大，负值将翻转精灵并缩放它，除非所使用的值正好是-1(在这种情况下，精灵只是沿着原点翻转而没有缩放)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="image_yscale" Set="true" Type="Real">该值设置应用于已分配给当前实例的精灵的垂直缩放(沿y轴)。1的比例表示不能缩放(1:1)，较小的值将缩小(例如，0.5是精灵高度的一半)，较大的值将扩大，负值将镜像精灵并缩放它，除非使用的值正好是-1(在这种情况下，精灵只是沿y轴镜像，没有缩放)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="mask_index" Set="true" Type="Asset.GMSprite">当你在GameMaker中定义一个对象时，你可以为它分配一个用于碰撞的掩码，而不是与所定义的精灵相对应的掩码。这个变量可以用来找到该掩码的sprite_index(或者如果没有分配精灵，它将返回-1)，或者为一个实例设置所选精灵的掩码。设置掩码索引意味着，例如，你可以拥有一个不规则形状的精灵实例，但给它一个从不同的精灵获得的圆形碰撞掩码。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sprite_height" Set="false" Type="Real">这个只读变量返回已分配给实例的精灵的高度。这个高度以像素为单位返回，将取决于image_yscale。如果你需要未缩放的高度，你应该使用sprite_get_height()。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sprite_index" Set="true" Type="Asset.GMSprite">该变量返回实例的当前精灵的索引，如果实例没有与之关联的精灵，则返回-1。你可以通过给它一个来自资源树的精灵的名字或者使用一个外部加载的精灵索引的变量来改变它，给实例一个不同的精灵。改变精灵并不会改变当前可见帧的索引，所以如果你改变了第3帧上的精灵，新的精灵就会以该帧可见的方式绘制出来(假设它有相同的帧数)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sprite_width" Set="false" Type="Real">这个只读变量返回已分配给实例的精灵的宽度。该宽度以像素为单位返回，并将依赖于image_xscale。如果你需要未缩放的宽度，你应该使用sprite_get_width()。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sprite_xoffset" Set="false" Type="Real">这个只读变量返回分配给实例的精灵的本地xoffset(精灵编辑器中定义的原点x组件)。这个xoffset以像素为单位返回，并将依赖于image_xscale，因此(例如)如果一个正方形的32x32精灵被定义为x原点为16，当这个精灵被缩放2时，这个变量将返回32。如果你需要未缩放的xoffset，你应该使用sprite_get_xoffset()。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="sprite_yoffset" Set="false" Type="Real">这个只读变量返回分配给实例的精灵的本地yoffset(精灵编辑器中定义的原点的y组件)。这个yoffset以像素为单位返回，并将依赖于image_yscale，因此(例如)如果一个正方形的32x32精灵被定义为y原点为16，当这个精灵被缩放2时，这个变量将返回32。如果你需要未缩放的yoffset，你应该使用sprite_get_yoffset()。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="timeline_index" Set="true" Type="Asset.GMTimeline">此变量保存当前与实例关联的时间线的索引。您可以将其设置为特定的时间线以使用该时间线，或者将其设置为-1以停止对实例使用时间线(如果没有为实例定义时间线，则也返回-1)。注意，这并没有开始时间线-为此使用变量timeline_running。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="timeline_loop" Set="true" Type="Bool">这个变量将返回时间线是否循环(true)或非循环(false)。您可以更改这个变量来切换循环的开启或关闭，并且它以负的时间线速度工作(如果时间线位置低于0，它将在最后定义的时刻重新开始)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="timeline_position" Set="true" Type="Real">该变量保存时间线当前所处的当前位置(时刻)。您可以更改此值以跳过时间线的部分内容，或重复部分内容，或从开始重新开始时间线。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="timeline_running" Set="true" Type="Bool">该变量保存所分配时间线的当前状态，如果正在运行则返回true，如果没有运行则返回false。您还可以将此变量设置为true或false，以便在任何时间开始和停止时间线。应该注意的是，停止的时间线不会重置，因此在稍后的时间重新启动它将从它被停止的确切时刻开始。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="timeline_speed" Set="true" Type="Real">通常情况下，在每一步中，时间线中的位置增加1，但是您可以通过将该变量设置为不同的值来更改此量。您可以使用实数(例如0.5或2.4)，如果值大于1，则可以在同一时间步内发生多个时刻(它们将按照时间线定义的相同顺序执行，因此不会跳过任何动作)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_camera" Set="true" Type="Array[Id.Camera]">该数组保存分配给给定视图端口的唯一相机ID，可以将其设置为一个新相机或读取当前相机，如果没有分配相机则返回-1。在一个房间中最多可以有8个活动的视图端口(数组值从0到7)，并且可以通过简单地将该变量设置为相机ID值(由camera_create()或camera_create_view()函数返回)来将相机分配给其中的任何一个。如果您已经通过Room Editor将相机设置为一个视图端口，那么该变量将保存该端口的相机ID。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_current" Set="false" Type="Real">这个只读变量只在Draw Event中有效，并返回正在呈现的当前视图端口。当您拥有不同的视图时，返回值将在绘制事件期间发生变化，因为绘制事件将连续为每个视图端口调用一次。因此，当(例如)您在游戏房间中使用view port[0]和view port[1]时，所有实例的draw事件将运行两次，每个端口一次，使用此变量您可以查看当前正在绘制的视图。通常，当多个视图端口在房间中同时可见时，这只用于将特定的细节渲染到单个端口。参见下面的示例代码。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_enabled" Set="true" Type="Bool">此变量控制是否启用房间内可见的任何视图端口。如果将视图端口设置为可见，然后禁用此选项，则整个房间将被绘制到按窗口大小缩放的屏幕上，而不是通过视图端口绘制不同的相机。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_hport" Set="true" Type="Array[Real]">此变量可用于获取或设置指定视图端口的高度。视口(或组合视口，如果不止一个处于活动状态)的高度定义了游戏开始时游戏窗口或背景画布的高度，因此在游戏开始后更改该值不会对游戏窗口大小产生明显影响，除非与函数window_set_size()一起调用。如果您的端口大小大于或小于分配给相机的端口大小，则相机视图将会缩小或放大以适应需要，如下图所示。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_surface_id" Set="true" Type="Array[Id.Surface]">使用此变量，您可以将给定视口的内容设置为绘制到表面，或者获取当前的表面id(如果已将一个id分配给视口)。在处理表面时，通常需要将屏幕的整个可见区域捕捉到表面上，因此可以使用此变量将其分配给一个视口。这意味着在所选视图中显示的所有内容都将被绘制到指定的表面上。视图现在不会被绘制到屏幕上，这意味着您需要:</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="view_visible" Set="true" Type="Array[Bool]">该变量可用于确定特定的视口当前是否可见。您还可以通过将该值设置为true(可见)或false(不可见)来设置该变量，以有效地&quot;打开&quot;或&quot;关闭&quot;视图。注意，即使您将视口设置为可见，如果视口未启用(使用内置变量view_enabled或在房间编辑器中启用它们)，则它们不会被绘制到屏幕上。</Variable>
		<Variable Deprecated="true" Get="true" Instance="false" Name="view_wport" Set="true" Type="Array[Real]">此变量可用于获取或设置指定视口的宽度。视口(或组合视口，如果不止一个处于活动状态)的宽度定义了游戏开始时游戏窗口或背景画布的宽度，因此在游戏开始后更改该值不会对游戏窗口大小产生明显影响，除非与函数window_set_size()一起调用。如果您的端口大小大于或小于分配给相机的端口大小，则相机视图将会缩小或放大以适应需要，如下图所示。</Variable>
		<Variable Deprecated="true" Get="true" Instance="false" Name="view_xport" Set="true" Type="Array[Real]">有了这个内置的数组，你可以获取或设置给定视口的x位置。视图端口是屏幕上绘制视图的区域，任何时候都可以有最多8个活动端口(该数组的值从0到7，包括0和7，共8个端口)。现在，GameMaker的默认设置是游戏窗口(或背景画布)与房间大小相同，但是当您激活视口和相机时，这种行为会发生变化，所有视口的边界框的总大小都会被使用。因此，如果你在两个不同的位置有两个不同的观察口，它们覆盖的总面积决定了游戏窗口的大小。下图说明了这一点:</Variable>
		<Variable Deprecated="true" Get="true" Instance="false" Name="view_yport" Set="true" Type="Array[Real]">有了这个内置的数组，你就可以获取或设置给定视口的y位置。视图端口是屏幕上绘制视图的区域，任何时候都可以有最多8个活动端口(该数组的值从0到7，包括0和7，共8个端口)。现在，GameMaker的默认设置是游戏窗口(或背景画布)与房间大小相同，但是当您激活视口和相机时，这种行为会发生变化，所有视口的边界框的总大小都会被使用。因此，如果你在两个不同的位置有两个不同的观察口，它们覆盖的总面积决定了游戏窗口的大小。下图说明了这一点:</Variable>
		<Variable Deprecated="true" Get="true" Instance="false" Name="debug_mode" Set="false" Type="Bool">当游戏在调试模式下运行时，这个只读变量返回true，当正常运行时返回false。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="fps" Set="false" Type="Real">在GameMaker中，有两种主要方法可以用来判断游戏的运行速度。游戏速度(在游戏选项中指定)和fps(每秒帧数)。这些值经常被混淆，但基本上一个是GameMaker应该在一秒钟内完成的游戏步骤数，而另一个(fps)是GameMaker在一秒钟内实际完成的CPU步骤数，最高可达房间速度本身的最大值。以获得真实的fps，即。每个游戏步骤的实际cpu步骤数，使用fps_real变量。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="fps_real" Set="false" Type="Real">在GameMaker中，有两种主要方法可以用来判断游戏的运行速度。游戏速度(在游戏选项中指定)和fps(每秒帧数)。这些值经常被混淆，但基本上一个是GameMaker在一秒钟内应该完成的游戏步骤数(游戏速度)，另一个是GameMaker在一秒钟内实际完成的CPU步骤数(实际fps)，这个值通常比游戏速度高得多，但会随着您的游戏变得更加复杂并使用更多处理能力来维持设定的房间速度而下降。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="application_surface" Set="false" Type="Id.Surface">这个全局范围的内置变量可用于使用任何表面函数访问应用程序表面。这个表面是永久可用的，也是GameMaker完成大部分绘图的地方。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="program_directory" Set="false" Type="String">这将返回存储游戏可执行文件的目录。然而，这可能并不总是有用的，特别是当一些设备从*.zip文件运行exe时，所以无论游戏从哪里运行，这都将返回相同的结果。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="temp_directory" Set="false" Type="String">这可以用来返回游戏每次运行时创建的临时目录(根目录不包含最后的&quot;\&quot;)。该目录将保存文件，在游戏运行时可以访问，但当游戏关闭时，它将被删除(连同它包含的所有文件)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="working_directory" Set="false" Type="String">Working_directory实际上可以返回两个不同的值，这取决于您使用它的目的。如果您正在将文件写入磁盘，working_directory将指向目标设备上为您的游戏保留的本地存储区域(在windows中，这是&quot;%LOCALAPPDATA%/gamedir/&quot;，其中&quot;gamedir&quot;是包含您的游戏名称的目录)。但是，当从磁盘读取时，working_directory可以是本地存储，也可以是存储包含文件的区域。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="event_data" Set="false" Type="Id.DsMap">该变量在范围上是全局的，当在手势事件中使用时用于保存DS map，在所有其他时间为-1。DS map的实际内容将取决于触发它的手势事件的类型，因此请参考这些事件的各个部分。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="keyboard_key" Set="true" Type="Constant.VirtualKey">用这个变量你可以得到当前被按下的键的键码，如果检查完成后没有键被按下，它将返回0。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="keyboard_lastchar" Set="true" Type="String">该变量存储最后一次按键的字符串。此变量不是只读的，您可以更改它，例如，如果您已经处理过它，可以将其设置为&quot;&quot;(空字符串)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="keyboard_lastkey" Set="true" Type="Constant.VirtualKey">这个变量指的是keyboard_key在前一帧中的值，返回那个键的键码(返回所有标准的键码常量)。这个变量不是只读的，您可以更改它，例如，如果您已经处理了它，就将其设置为-1。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="keyboard_string" Set="true" Type="String">该变量保存一个字符串，该字符串包含键盘上输入的最后(最多)1024个字符。该字符串将只包含键入的可打印字符，但它将通过擦除最后一个字符来正确响应按退格键。此变量不是只读的，您可以更改它，例如，如果您已经处理过它，可以将其设置为&quot;&quot;(空字符串)，并且您可以使用字符串函数来操作它。注意，当使用屏幕虚拟键盘时，只有这个变量会随着键盘输入而更新。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="mouse_button" Set="true" Type="Constant.MouseButton">这个只读变量返回当前被按下的鼠标按钮(当前，在这个步骤中),并且可以返回除mb_any之外的任何特殊鼠标常量。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="mouse_lastbutton" Set="true" Type="Constant.MouseButton">该变量返回最后一次按下的鼠标按钮，并且可以返回除mb_any之外的任何特殊鼠标常量(您也可以将该变量设置为其中一个常量)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="mouse_x" Set="false" Type="Real">这个只读变量返回鼠标在房间内的当前x轴位置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="mouse_y" Set="false" Type="Real">这个只读变量返回鼠标在房间内的当前y轴位置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="cursor_sprite" Set="true" Type="Asset.GMSprite">设置此变量将指示GameMaker使用指定的精灵作为光标(基本上是将其设置为每一步的当前鼠标x/y位置)。默认值是-1，即没有用于光标的精灵，但你可以从游戏资源或从外部资源导入任何精灵索引。注意，没有办法控制动画速度或image_index，所以如果精灵有子图像，这些将以与房间速度相同的速度循环。要删除光标精灵，您可以再次将此变量设置为-1。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="game_display_name" Set="false" Type="String">这个只读变量返回目标平台上游戏的显示名称，就像在game Options中设置的那样。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="game_id" Set="false" Type="Real">这个只读变量返回你所创建的游戏的唯一标识符。如果你需要一个唯一的文件名，或者其他需要识别游戏的东西，你可以使用这个。这可以在游戏选项中设置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="game_project_name" Set="false" Type="String">这个只读变量在目标平台以&quot;保存友好&quot;的格式返回游戏的显示名称。如果显示名称包含任何文件名不允许的字符，它们将自动替换为&quot;_&quot;。显示名称可以在游戏选项中设置。注意，由于HTML5对文件名没有限制，所以这个字符串可能与game_display_name返回的字符串相同。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="game_save_id" Set="false" Type="String">这个只读变量将返回你的游戏用来保存文件的目录的完整路径ID。这个目录对其他应用程序可能可见，也可能不可见，这取决于平台，在HTML5目标上，它将返回一个空字符串。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_day" Set="false" Type="Real">这个只读变量将返回1到31之间的值，具体取决于月份。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_hour" Set="false" Type="Real">这个只读变量将根据系统的默认时区(即:本地时间)返回与当前时刻对应的小时。您可以使用date_set_timezone()函数来更改基本时区。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_minute" Set="false" Type="Real">这个只读变量将返回与当前时刻对应的分钟数。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_month" Set="false" Type="Real">这个只读变量以数值形式返回当前月份，其中1是一月，12是十二月。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_second" Set="false" Type="Real">这个只读变量将返回与当前时刻对应的秒数。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_time" Set="false" Type="Real">这个只读变量将返回自游戏启动以来所经过的毫秒数。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_weekday" Set="false" Type="Real">这个只读变量将返回工作日作为值，其中Sunday为0,Saturday为6。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="current_year" Set="false" Type="Real">这个只读变量将返回当前年份。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="delta_time" Set="false" Type="Real">增量计时的目的是消除计算机在处理复杂图形或大量代码时产生的滞后或慢的影响。这是一个可以添加到物体速度上的值，以便它们最终以相同的速度移动，而不考虑延迟。这在GameMaker中是通过使用每个步骤的只读变量delta_time来实现的，因为它以微秒为单位衡量一个步骤和下一个步骤之间所经过的时间(1微秒是1,000,000分之一秒)。因此，变量delta_time可以用来计算游戏角色需要移动多快才能弥补游戏中的延迟高峰。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="os_browser" Set="false" Type="Constant.BrowserType">这个只读变量包含GameMaker告诉你当前游戏运行在哪个浏览器(如果有的话)的各种常量之一(如下所示)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="os_device" Set="false" Type="Constant.DeviceType">这个只读变量包含下面列出的各种常量值之一，告诉你当前在哪个设备上运行游戏。注意这个变量已被弃用，取而代之的是函数os_get_info()，它返回关于运行游戏的设备的更准确的信息。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="os_type" Set="false" Type="Constant.OperatingSystem">这个只读变量包含各种常量之一，GameMaker必须告诉你游戏是针对哪个操作系统创建的。注意，这并不一定与运行它的设备的操作系统相同，因为——例如——你的游戏可以运行在Amazon Fire操作系统上，但将为Android平台构建(在这种情况下，os_type将为os_android)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="os_version" Set="false" Type="Real">这个变量会告诉你运行游戏的操作系统的版本号。例如，如果在Windows 10上运行它，那么os_version将等于655360。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_active" Set="true" Type="Bool">该变量控制实例当前是否&quot;激活(active)&quot;。将其设置为false将阻止实例参与物理世界，将其设置为true将使其再次参与。注意，这与禁用实例不同，因为实例仍然在屏幕上可见，仍然可以通过代码进行更改，而此函数只是阻止它参与物理模拟</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_angular_damping" Set="true" Type="Real">这个变量可以用来设置实例的角阻尼，也可以用来获取当前的角阻尼。阻尼是物理启用实例的角度旋转&quot;阻力&quot;的数量，较低的值允许实例在碰撞后旋转得更快(例如)，较高的值使它需要更有力的推动和更慢的旋转</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_angular_velocity" Set="true" Type="Real">该变量可用于设置实例的角速度，也可用于获取当前角速度，单位为度/秒，使用的值可以为正(用于顺时针旋转)或负(用于逆时针旋转)。如果你将此设置在一个以前是静态的实例上(例如:它的密度为0)，它将成为一个运动对象并开始旋转</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_bullet" Set="true" Type="Bool">这个变量定义实例是否快速移动(例如子弹)。默认值为false，但如果设置为true，这将告诉GameMaker实例将以如此高的速度移动，它将需要更昂贵的碰撞检测，以确保它不会在未检测到的情况下通过其他实例</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_collision_points" Set="false" Type="Real">这个只读变量返回碰撞中两个对象之间检测到的碰撞点的数量</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_collision_x" Set="false" Type="Real">这个只读数组返回在两个启用物理的实例之间的碰撞中检测到的所有点的x位置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_collision_y" Set="false" Type="Real">这个只读数组返回在两个启用物理的实例之间的碰撞中检测到的所有点的y位置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_col_normal_x" Set="false" Type="Real">这个只读变量返回与phy_collision_x数组值对应的碰撞法线的x分量。对于每个接触点都有一个相关的接触法线(对于碰撞中的所有接触点通常是相同的法线)。这个接触法线是一个单位向量，它从碰撞中的一个实例指向另一个实例，可以用来计算解决碰撞的正确&quot;推&quot;方向</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_col_normal_y" Set="false" Type="Real">这个只读变量返回与phy_collision_y数组值对应的碰撞法线的y分量。对于每个接触点都有一个相关的接触法线(对于碰撞中的所有接触点通常是相同的法线)。这个接触法线是一个单位向量，它从碰撞中的一个实例指向另一个实例，可以用来计算解决碰撞的正确&quot;推&quot;方向</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_com_x" Set="false" Type="Real">这个只读变量将返回实例重心的x位置。这是根据适当函数定义的实例的密度、惯性和质量自动计算的</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_com_y" Set="false" Type="Real">这个只读变量将返回实例重心的y位置。这是根据适当函数定义的实例的密度、惯性和质量自动计算的</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_dynamic" Set="false" Type="Bool">动态实例是在物理世界中完全模拟的实例，如果被检查的实例是完全模拟的，这个只读变量将返回true，否则返回false</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_fixed_rotation" Set="true" Type="Bool">此变量可用于设置实例是否会受到旋转力的影响(默认值为false)。如果设置为true，没有外力(来自编码的脉冲或力，或来自碰撞)会影响实例的旋转值，这必须使用phy_rotation变量手动设置</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_inertia" Set="false" Type="Real">惯性是衡量使某物开始或停止运动的难度，因此该只读变量的值越低，就越容易使实例运动，而值越高，则需要更大的力来使其开始运动</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_kinematic" Set="false" Type="Bool">如果实例被归类为运动学对象，则该只读变量将返回true，否则返回false。运动学实例具有无限质量(密度为0)但可以移动。因此，要使实例运动，首先要创建一个静态实例，然后设置一个或多个与运动相关的实例变量(即:phy_speed_x、phy_speed_y或phy_angular_velocity)</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_linear_damping" Set="true" Type="Real">此变量可用于设置实例的线性阻尼，也可用于获取当前的线性阻尼。阻尼是物理启用实例向前移动的&quot;阻力&quot;量，较低的值允许实例更快地移动和加速，较高的值使其需要更有力的推动</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_linear_velocity_x" Set="true" Type="Real">该变量可用于获取或更改实例的线速度向量的x分量，并以每秒像素数定义(有关每步像素数，请参见phy_speed_x)。为静态实例(例如:密度为0的实例)更改此属性会将其转换为运动实例</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_linear_velocity_y" Set="true" Type="Real">该变量可用于获取或更改实例的线速度向量的y分量，并以每秒像素数定义(有关每步像素数，请参见phy_speed_y)。为静态实例(例如:密度为0的实例)更改此属性会将其转换为运动实例</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_mass" Set="false" Type="Real">此只读变量以千克为单位返回实例的质量。该值是根据指定装置的表面积及其密度值自动计算的，但可以使用函数physics_mass_properties()进行更改。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_position_x" Set="true" Type="Real">该变量可用于获取(或设置)游戏房间物理世界中实例的x位置。注意，当通过直接设置此变量来移动实例时，物理世界可能会出现错误，因为这将中断连续模拟。这个变量是实例变量x的物理等价物。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_position_xprevious" Set="false" Type="Real">该变量可用于获取(或设置)游戏房间物理世界中实例的前一个x位置。这是上一步到当前步的物理世界中实例的位置。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_position_y" Set="true" Type="Real">该变量可用于获取(或设置)游戏房间物理世界中实例的y位置。注意，当通过直接设置此变量来移动实例时，物理世界可能会出现错误，因为这将中断连续模拟。这个变量是实例变量y的物理等价物。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_position_yprevious" Set="false" Type="Real">该变量可用于获取(或设置)游戏房间物理世界中实例的前一个y位置。这是物理世界中实例在当前步骤之前的位置</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_rotation" Set="true" Type="Real">该变量可用于获取(或设置)实例夹具的角度，单位为度，类似于设置或获取image_angle。然而，注意，在物理世界中，旋转的计算方式与正常的GameMaker游戏世界相反，这意味着像point_direction()这样的向量函数应该修改其返回值(简单地将正数变为负数应该可以解决这个问题)。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_sleeping" Set="false" Type="Bool">该只读变量返回实例当前是否&quot;休眠&quot;(true)或&quot;非休眠&quot;(false)，&quot;休眠&quot;实例是不主动参与任何物理模拟的实例。当一个实例处于静止状态且不与另一个实例发生碰撞时，GameMaker会让对象休眠以节省模拟周期</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_speed" Set="false" Type="Real">此只读变量返回启用物理的实例的当前速度，以每步像素为单位定义。如果需要改变该值，必须使用变量phy_speed_x和phy_speed_y改变x和y矢量。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_speed_x" Set="true" Type="Real">该变量可用于获取或更改实例的线速度向量的x分量，并以每步像素数定义(有关每秒像素数，请参见phy_linear_velocity_x)。为静态实例(例如:密度为0的实例)更改此属性会将其转换为运动实例。</Variable>
		<Variable Deprecated="false" Get="true" Instance="true" Name="phy_speed_y" Set="true" Type="Real">该变量可用于获取或更改实例的线速度向量的y分量，并以每步像素数定义(有关每秒像素数，请参见phy_linear_velocity_y)。为静态实例(例如:密度为0的实例)更改此属性会将其转换为运动实例。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="browser_height" Set="false" Type="Real">这个变量保存游戏运行时浏览器的高度(以像素为单位)。如果没有浏览器，则返回窗口大小。下图说明了该变量与窗口函数中可用的其余定位函数的关系。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="browser_width" Set="false" Type="Real">这个变量保存游戏运行时浏览器的宽度(以像素为单位)。如果没有浏览器，则返回窗口大小。下图说明了该变量与窗口函数中可用的其余定位函数的关系。</Variable>
		<Variable Deprecated="false" Get="true" Instance="false" Name="webgl_enabled" Set="false" Type="Bool">这个只读变量将返回你的游戏是否启用了WebGL。它只适用于那些通过浏览器运行的游戏(即HTML5)，对于所有其他平台，它将返回true。</Variable>
		<Variable Deprecated="true" Get="true" Instance="false" Name="argument_relative" Set="false" Type="Real"/>
