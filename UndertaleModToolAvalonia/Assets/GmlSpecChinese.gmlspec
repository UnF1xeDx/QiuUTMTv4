			<Parameter Name="month" Optional="false" Type="Real">要检查的月份。</Parameter>
			<Parameter Name="day" Optional="false" Type="Real">要检查的日子。</Parameter>
			<Parameter Name="hour" Optional="false" Type="Real">要检查的时间。</Parameter>
			<Parameter Name="minute" Optional="false" Type="Real">要检查的时间。</Parameter>
			<Parameter Name="second" Optional="false" Type="Real">第二个检查。</Parameter>
		</Function>
