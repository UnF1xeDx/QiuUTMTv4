		</Function>
		<Function Deprecated="false" Name="layer_fx_is_enabled" Pure="false" ReturnType="Bool">
			<Description>此函数用于检查指定图层是否启用了FX。</Description>
			<Parameter Name="layer_name_or_id" Optional="false" Type="String,Id.Layer">要修改的图层的名称或ID</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_define_player" Pure="false" ReturnType="Undefined">
			<Description>此函数定义了回滚多人游戏中玩家使用的对象。</Description>
			<Parameter Name="player_object" Optional="false" Type="Asset.GMObject">应该用于玩家的对象类型</Parameter>
			<Parameter Name="layer_name" Optional="true" Type="String">将创建的实例指定给的层名称(默认为&quot;实例&quot;)</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_define_input" Pure="false" ReturnType="Undefined">
