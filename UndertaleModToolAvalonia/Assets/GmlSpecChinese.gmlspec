			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
			<Parameter Name="surface_id" Optional="false" Type="Id.Surface"/>
		</Function>
		<Function Deprecated="false" Name="view_set_visible" Pure="false" ReturnType="Undefined">
			<Description>此函数可用于设置给定视图端口的可见性。此函数接受视图端口索引(从0到7)和一个布尔值，如果可见则为true，如果不可见则为false。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
			<Parameter Name="visible" Optional="false" Type="Bool">可见性切换(true为可见，false为不可见)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_set_wport" Pure="false" ReturnType="Real">
			<Description>此函数可以用来设置给定视图端口的宽度。给出视图端口索引(从0到7)和要使用的新宽度。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
			<Parameter Name="w" Optional="false" Type="Real">新的宽度(像素)</Parameter>
		</Function>
		<Function Deprecated="false" Name="view_set_xport" Pure="false" ReturnType="Undefined">
			<Description>此函数可以用来设置给定视图端口的x位置。您将给出视图端口索引(从0到7)和将其放置的新位置。</Description>
			<Parameter Name="view_port" Optional="false" Type="Real">目标的视口(0 - 7)</Parameter>
			<Parameter Name="x" Optional="false" Type="Real">新的x坐标</Parameter>
