		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_define_mock_input" Pure="false" ReturnType="Undefined">
			<Description>此函数定义了回滚系统在同步测试期间使用的模拟输入。</Description>
			<Parameter Name="player_id" Optional="false" Type="Real">为其设置模拟输入的玩家id</Parameter>
			<Parameter Name="input_struct" Optional="false" Type="Struct">包含要模仿的键码的结构</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_define_input_frame_delay" Pure="false" ReturnType="Undefined">
			<Description>此函数设置固定的本地输入帧延迟。</Description>
			<Parameter Name="delay" Optional="false" Type="Real">用于本地输入帧延迟的帧数</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_define_extra_network_latency" Pure="false" ReturnType="Undefined">
			<Description>此函数设置了一个额外的等待时间，添加到所有发送和接收的网络消息中。这可以用来为本地玩家模拟更差的网络条件。</Description>
			<Parameter Name="latency" Optional="false" Type="Real">要添加的延迟毫秒数</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_use_manual_start" Pure="false" ReturnType="Undefined">
			<Description>此函数支持手动启动，这意味着一旦所有人都连接上了，游戏就不会自动启动，而是等待rollback_start_game被调用。</Description>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_create_game" Pure="false" ReturnType="Undefined">
			<Description>此函数连接到GXC并创建一个指定大小的游戏实例。用户需要登录到GXC。</Description>
			<Parameter Name="num_players" Optional="false" Type="Real">请求空间的玩家数量</Parameter>
			<Parameter Name="sync_test" Optional="true" Type="Bool">启用开发同步测试的标志(可选，默认为真)</Parameter>
			<Parameter Name="region" Optional="true" Type="String">要连接的区域的名称</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_join_game" Pure="false" ReturnType="Bool">
			<Description>此函数检查游戏是否是通过GXC游戏的邀请开始的，如果是，就加入游戏。</Description>
			<Parameter Name="dry_run" Optional="true" Type="Bool">标志来检查您是否应该加入，而不是实际加入</Parameter>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_start_game" Pure="false" ReturnType="Undefined">
			<Description>此函数启动当前游戏。</Description>
		</Function>
		<Function Deprecated="false" FeatureFlag="rollback" Name="rollback_leave_game" Pure="false" ReturnType="Undefined">
