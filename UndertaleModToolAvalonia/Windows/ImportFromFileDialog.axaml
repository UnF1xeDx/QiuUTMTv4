<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:l="clr-namespace:UndertaleModToolAvalonia"
        mc:Ignorable="d"
        x:Class="UndertaleModToolAvalonia.ImportFromFileDialog"
        x:DataType="l:ImportFromFileDialog"
        Title="Import From File"
        Height="650" Width="700" MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Source file selection -->
        <TextBlock Grid.Row="0" Text="Source file" FontSize="16" Margin="0,0,0,4"/>
        <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <Button Name="BrowseButton" Content="Browse..." Click="BrowseButton_Click"
                    Width="80" DockPanel.Dock="Right" Margin="5,0,0,0"/>
            <TextBox Name="SourceFilePathTextBox" IsReadOnly="True"
                     VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Conflict resolution -->
        <TextBlock Grid.Row="2" Text="Conflict resolution" FontSize="14" Margin="0,4,0,4"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <RadioButton Name="SkipRadio" Content="Skip" IsChecked="True"
                         Margin="0,0,15,0" FontSize="13"/>
            <RadioButton Name="OverwriteRadio" Content="Overwrite"
                         Margin="0,0,15,0" FontSize="13"/>
            <RadioButton Name="RenameRadio" Content="Rename" FontSize="13"/>
        </StackPanel>

        <!-- Include dependencies -->
        <CheckBox Name="ImportDependenciesCheck" Grid.Row="4"
                  Content="Include Dependencies" IsChecked="True"
                  Margin="0,3,0,6" FontSize="13"/>

        <!-- Two-column resource lists -->
        <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Available resources (left) -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Available resources" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <ListBox Name="AvailableList" Grid.Row="1" SelectionMode="Multiple"
                         DoubleTapped="AvailableList_DoubleTapped"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,4,0,0">
                    <Button Content="Select All" Click="SelectAllButton_Click"
                            Width="70" FontSize="11" Margin="0,0,5,0"/>
                    <Button Content="Deselect All" Click="DeselectAllButton_Click"
                            Width="75" FontSize="11"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"/>

            <!-- Selected for import (right) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Selected for import" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <ListBox Name="SelectedList" Grid.Row="1"
                         DoubleTapped="SelectedList_DoubleTapped"/>
            </Grid>
        </Grid>

        <!-- Separator -->
        <Separator Grid.Row="6" Margin="0,8,0,0"/>

        <!-- Import / Cancel buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Name="ImportButton" Content="Import" FontSize="16"
                    Width="100" Height="36" Click="ImportButton_Click"/>
            <Button Content="Cancel" FontSize="16"
                    Width="100" Height="36" Margin="15,0,0,0"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
